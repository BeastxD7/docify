# Local development .env — copy to backend/.env
# Infra runs in Docker (docker-compose.infra.yml), backend + worker run with uv locally.

# ── LLM — using local Ollama with llama3.1:8b ────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# For production, swap to Anthropic:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Embeddings — using local Ollama with nomic-embed-text ─────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL shared with LLM above

# For production, swap to OpenAI:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# OPENAI_API_KEY=your_openai_key_here

# ── Databases (localhost because infra is in Docker, ports exposed) ────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=docify
POSTGRES_USER=docify
POSTGRES_PASSWORD=docify

REDIS_URL=redis://localhost:6379/0

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=docify_chunks

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=docify_neo4j

# ── Files ─────────────────────────────────────────────────────────────────────
# Point this to the uploads folder in your project root
UPLOAD_DIR=../uploads
MAX_FILE_SIZE_MB=500

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
